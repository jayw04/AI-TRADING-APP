//@version=5
// Symbol-selection screener used to choose backtest symbols by strategy fit (15m, ~3mo).
// segER   = avg of rolling 100-bar Kaufman Efficiency Ratio (trend QUALITY of tradeable legs)
// avgADX  = avg directional strength
// avgCI   = avg Choppiness Index (high = range/chop -> mean-reversion fit; low = trend)
// avgTR%  = avg per-bar true range as % of price (noise)
// TrendScore (computed offline) = segER / avgTR%  -> trend quality per unit noise (trend-follower fit)
indicator("Trendiness Screener", overlay=true)
n = input.int(1600, "Avg window (~3mo 15m)")
w = input.int(100, "Segment window (bars)")
segChg = math.abs(close - close[w])
segVol = math.sum(math.abs(close - close[1]), w)
segER = segVol != 0 ? segChg / segVol : 0
avgSegER = ta.sma(segER, n)
ci = 100 * math.log10(math.sum(ta.tr, w) / (ta.highest(high, w) - ta.lowest(low, w))) / math.log10(w)
avgCI = ta.sma(ci, n)
[dp, dm, adxv] = ta.dmi(14, 14)
avgADX = ta.sma(adxv, n)
avgTRpct = ta.sma(ta.tr / close * 100, n)
var table t = table.new(position.top_right, 2, 5, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "metric", bgcolor=color.gray, text_color=color.white)
    table.cell(t, 1, 0, syminfo.ticker, bgcolor=color.gray, text_color=color.white)
    table.cell(t, 0, 1, "segER")
    table.cell(t, 1, 1, str.tostring(avgSegER, "#.###"))
    table.cell(t, 0, 2, "avgADX")
    table.cell(t, 1, 2, str.tostring(avgADX, "#.#"))
    table.cell(t, 0, 3, "avgCI")
    table.cell(t, 1, 3, str.tostring(avgCI, "#.#"))
    table.cell(t, 0, 4, "avgTR%")
    table.cell(t, 1, 4, str.tostring(avgTRpct, "#.##"))
