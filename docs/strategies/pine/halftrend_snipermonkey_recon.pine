//@version=5
// #1 — HalfTrend [SNIPERMONKEY-style recon]. The exact SNIPERMONKEY script is closed; this is a
// faithful reconstruction of the canonical everget HalfTrend engine wrapped in long/short auto-flip
// entries (Amplitude 2, Channel Deviation 2). Test config: 15m, US-RTH gating, 100% equity, $10k.
strategy("HalfTrend Strategy [SNIPERMONKEY-style recon]", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     initial_capital=10000, commission_type=strategy.commission.percent,
     commission_value=0.02, slippage=2, pyramiding=0, calc_on_every_tick=false)

amplitude        = input.int(2, "Amplitude")
channelDeviation = input.float(2.0, "Channel Deviation")
useSession       = input.bool(true, "Restrict entries to US RTH")
sess             = input.session("0930-1600", "Session (ET)")
allowShort       = input.bool(true, "Allow shorts (auto-flip)")
// Set useDateFilter=true for the last-3-month window (entries only after Mar 29 2026).
useDateFilter    = input.bool(false, "Limit to backtest start")

var int trend = 0
var int nextTrend = 0
var float maxLowPrice = nz(low[1], low)
var float minHighPrice = nz(high[1], high)
var float up = 0.0
var float down = 0.0

atr2 = ta.atr(100) / 2.0
dev = channelDeviation * atr2

highPrice = high[math.abs(ta.highestbars(amplitude))]
lowPrice  = low[math.abs(ta.lowestbars(amplitude))]
highma    = ta.sma(high, amplitude)
lowma     = ta.sma(low, amplitude)

if nextTrend == 1
    maxLowPrice := math.max(lowPrice, maxLowPrice)
    if highma < maxLowPrice and close < nz(low[1], low)
        trend := 1
        nextTrend := 0
        minHighPrice := highPrice
else
    minHighPrice := math.min(highPrice, minHighPrice)
    if lowma > minHighPrice and close > nz(high[1], high)
        trend := 0
        nextTrend := 1
        maxLowPrice := lowPrice

if trend == 0
    if not na(trend[1]) and trend[1] != 0
        up := na(down[1]) ? down : down[1]
    else
        up := na(up[1]) ? maxLowPrice : math.max(maxLowPrice, up[1])
else
    if not na(trend[1]) and trend[1] != 1
        down := na(up[1]) ? up : up[1]
    else
        down := na(down[1]) ? minHighPrice : math.min(minHighPrice, down[1])

ht = trend == 0 ? up : down
plot(ht, "HalfTrend", color = trend == 0 ? color.green : color.red, linewidth=2)

// everget semantics: trend==0 is UP (buy), trend==1 is DOWN (sell)
buySignal  = trend == 0 and trend[1] == 1
sellSignal = trend == 1 and trend[1] == 0
inSession  = not useSession or not na(time(timeframe.period, sess))
inDate     = not useDateFilter or time >= timestamp(2026, 3, 29, 0, 0)

if buySignal and inSession and inDate
    strategy.entry("BUY", strategy.long)
if sellSignal and inSession and inDate
    if allowShort
        strategy.entry("SELL", strategy.short)
    else
        strategy.close("BUY")
