{
  "__comment": "P11 §2 (ADR 0021) — Operations & Reliability dashboard. dashboard_version 1.0. Import into a Grafana with a Prometheus datasource scraping the backend /metrics. Panels are grouped Platform (top) then Actor.",
  "title": "Trading Workbench — Operations & Reliability",
  "uid": "tw-operations",
  "tags": ["p11", "operations", "dashboard_version:1.0"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {"id": 1, "type": "row", "title": "Platform", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}},
    {
      "id": 2, "type": "stat", "title": "Scheduler success rate (24h)",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 1},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null}, {"color": "yellow", "value": 0.99}, {"color": "green", "value": 0.999}]}}},
      "targets": [{"expr": "sum(increase(workbench_scheduler_job_events_total{event=\"executed\"}[24h])) / clamp_min(sum(increase(workbench_scheduler_job_events_total[24h])), 1)", "legendFormat": "success"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "Scheduler events (executed / error / missed)",
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 1},
      "targets": [{"expr": "sum by (event) (rate(workbench_scheduler_job_events_total[5m]))", "legendFormat": "{{event}}"}]
    },
    {
      "id": 4, "type": "timeseries", "title": "Job last-success age (s)",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 7},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [{"expr": "time() - workbench_scheduler_job_last_success_timestamp", "legendFormat": "{{job_id}}"}]
    },
    {"id": 10, "type": "row", "title": "Actors", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13}},
    {
      "id": 11, "type": "timeseries", "title": "Overlay outcomes",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
      "targets": [{"expr": "sum by (outcome) (rate(workbench_overlay_actions_total[5m]))", "legendFormat": "{{outcome}}"}]
    },
    {
      "id": 12, "type": "timeseries", "title": "Automation runs (breaker_monitor, by outcome)",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "sum by (actor, outcome) (rate(workbench_automation_runs_total[5m]))", "legendFormat": "{{actor}}/{{outcome}}"}]
    },
    {
      "id": 13, "type": "stat", "title": "Fail-open rate (24h)",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 20},
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [
        {"color": "green", "value": null}, {"color": "yellow", "value": 0.001}, {"color": "red", "value": 0.01}]}}},
      "targets": [{"expr": "sum(increase(workbench_overlay_actions_total{outcome=\"fail_open\"}[24h])) / clamp_min(sum(increase(workbench_overlay_actions_total[24h])), 1)", "legendFormat": "fail-open"}]
    }
  ]
}
