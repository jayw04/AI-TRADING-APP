# --- Backend ---
WORKBENCH_ENV=development
WORKBENCH_HOST=127.0.0.1
WORKBENCH_PORT=8000
WORKBENCH_DB_URL=sqlite+aiosqlite:///./data/workbench.sqlite
WORKBENCH_LOG_LEVEL=INFO
WORKBENCH_DEV_USER_EMAIL=jay@globalcomplyai.com

# --- MCP server ---
MCP_HOST=127.0.0.1
MCP_PORT=8765
MCP_BACKEND_URL=http://127.0.0.1:8000
MCP_BACKEND_TOKEN=change-me-shared-secret

# --- Frontend ---
VITE_API_BASE=http://127.0.0.1:8000
VITE_WS_BASE=ws://127.0.0.1:8000

# --- Anthropic (server-side; backend -> api.anthropic.com) ---
# Used by the BACKEND (FastAPI), not Claude Code. Consumers:
#   P3: in-app agent chat panel (B1 read-only + B2 interactive Q&A).
#   P6: scheduled Agent Strategy runs (engine calls Anthropic with the
#       workbench MCP server attached as tools).
#   P7: "Draft strategy with Claude" -> backend generates Python files.
# Empty key disables the agent; the runtime refuses to start a session
# with a clear error rather than crashing on first call.
ANTHROPIC_API_KEY=
AGENT_DEFAULT_MODEL=claude-haiku-4-5-20251001
AGENT_DAILY_BUDGET_USD=2.0

# --- Alpaca (used from P1; placeholder now) ---
# Paper credentials are required to run P1 in the default safe mode.
# Live credentials remain blank until you explicitly opt in to live trading.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# Alpaca hosts. Defaults match the public Alpaca endpoints; override only for
# sandbox/mock testing. The alpaca-py SDK can derive these from a paper flag,
# but we keep them as explicit env vars so the active host is auditable.
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Market-data feed tier. `iex` is the free real-time IEX feed; `sip` requires
# a paid Alpaca data plan (full consolidated tape). Leave as `iex` for P0.
ALPACA_DATA_FEED=iex

# --- Market data cache (P2) ---
# Where OHLCV parquet files live (relative to apps/backend/) + soft LRU cap.
WORKBENCH_BARS_CACHE_ROOT=bars_cache
WORKBENCH_BARS_CACHE_MAX_GB=5.0
