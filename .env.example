# --- Backend ---
WORKBENCH_ENV=development
WORKBENCH_HOST=127.0.0.1
WORKBENCH_PORT=8000
WORKBENCH_DB_URL=sqlite+aiosqlite:///./data/workbench.sqlite
WORKBENCH_LOG_LEVEL=INFO
WORKBENCH_DEV_USER_EMAIL=jay@globalcomplyai.com

# --- MCP server ---
MCP_HOST=127.0.0.1
MCP_PORT=8765
MCP_BACKEND_URL=http://127.0.0.1:8000
MCP_BACKEND_TOKEN=change-me-shared-secret

# --- Frontend ---
VITE_API_BASE=http://127.0.0.1:8000
VITE_WS_BASE=ws://127.0.0.1:8000

# --- Anthropic (server-side; backend -> api.anthropic.com) ---
# Used by the BACKEND (FastAPI), not Claude Code. Two consumers:
#   P6: scheduled Agent Strategy runs (engine calls Anthropic with the
#       workbench MCP server attached as tools).
#   P7: "Draft strategy with Claude" -> backend generates Python files.
# Placeholder for P0. Required before P6.
ANTHROPIC_API_KEY=

# --- Alpaca (used from P1; placeholder now) ---
# Paper credentials are required to run P1 in the default safe mode.
# Live credentials remain blank until you explicitly opt in to live trading.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
